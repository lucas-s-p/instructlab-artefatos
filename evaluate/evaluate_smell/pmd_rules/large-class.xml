<?xml version="1.0"?>
<ruleset name="Large Class"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0
                             https://pmd.sourceforge.io/ruleset_2_0_0.xsd">
  <description>
    Detects Large Class via NCSS statement count at the class level.
  </description>

  <rule ref="category/java/design.xml/NcssCount">
    <properties>
      <!-- `methodReportLevel` should be high to avoid triggering in individual methods. -->
      <property name="methodReportLevel" value="999"/>
      <!-- classReportLevel=40 NCSS statements per class -->
      <property name="classReportLevel"  value="40"/>
    </properties>
  </rule>
</ruleset>
